---
import { SITE } from '../lib/site';
import { getCategories } from '../lib/posts';
const allCats = (await getCategories()).sort((a, b) => a.name.localeCompare(b.name));
const notice = allCats.find((c) => c.name === 'Notice');
const categories = allCats.filter((c) => c.name !== 'Notice');
const path = Astro.url.pathname;
const isHome = path === '/' || path === '/index.html' || /^\/page\//.test(path);
const here = (href: string) => path === href;
---
<aside class="sidebar" id="sidebar" aria-label="사이드 메뉴">
  <div class="sidebar-inner">
    <p class="s-tagline">{SITE.tagline}</p>

    <nav class="s-nav" aria-label="주 메뉴">
      <a href="/" class={isHome ? 'active' : ''}>홈</a>
      <a href="/about.html" class={here('/about.html') ? 'active' : ''}>About</a>
      <a href="/tags.html" class={here('/tags.html') ? 'active' : ''}>태그</a>
      <a href="/archive.html" class={here('/archive.html') ? 'active' : ''}>아카이브</a>
      <a href="/locked.html" class={here('/locked.html') ? 'active' : ''}>🔒 비공개</a>
      <a href="/vault.html" class={here('/vault.html') ? 'active' : ''}>📦 보관함</a>
      <a href="/search.html" class={here('/search.html') ? 'active' : ''}>검색</a>
    </nav>

    {notice && (
      <a class:list={['s-notice', here('/categories/Notice.html') && 'active']} href="/categories/Notice.html">
        <span class="ico" aria-hidden="true">📢</span><span>공지</span><span class="n">{notice.count}</span>
      </a>
    )}

    <details class="s-group" open>
      <summary>
        카테고리 <span class="s-count">{categories.length}</span>
        <svg class="chev" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
      </summary>
      <div class="s-cats">
        {categories.map((c) => (
          <a href={`/categories/${encodeURIComponent(c.name)}.html`} class={here(`/categories/${encodeURIComponent(c.name)}.html`) ? 'active' : ''}>
            <span>{c.name}</span><span class="n">{c.count}</span>
          </a>
        ))}
      </div>
    </details>

    <div class="s-foot">
      <a href={SITE.social.github} rel="noopener" target="_blank">GitHub</a>
      <a href="/feed.xml">RSS</a>
    </div>
  </div>
</aside>
<div class="scrim" id="scrim" hidden></div>
