---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="검색" description="사이트 내 글 검색">
  <div class="container">
    <h1 class="page-title">검색</h1>
    <p class="page-sub">글 제목과 본문에서 검색합니다.</p>
    <!-- Pagefind: 빌드 시 /pagefind/ 인덱스가 생성됩니다 (dev 서버에선 동작 안 함) -->
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <div id="search"></div>
  </div>
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      if (!window.PagefindUI) return;
      const ui = new window.PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
        pageSize: 8,
        translations: {
          placeholder: '검색어를 입력하세요',
          clear_search: '지우기',
          load_more: '더 보기',
          search_label: '사이트 검색',
          zero_results: '"[SEARCH_TERM]" 검색 결과가 없습니다',
          many_results: '"[SEARCH_TERM]" 검색 결과 [COUNT]개',
          one_result: '"[SEARCH_TERM]" 검색 결과 [COUNT]개',
          searching: '"[SEARCH_TERM]" 검색 중...',
        },
      });
      const q = new URLSearchParams(location.search).get('q');
      if (q) ui.triggerSearch(q);
    });
  </script>
</BaseLayout>
