---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../lib/posts';

const entries = (await getCollection('vault'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BaseLayout title="📦 보관함" description="비밀번호로 보호된 보관 글 목록" noindex={true}>
  <div class="container">
    <h1 class="page-title">📦 보관함</h1>
    <p class="page-sub">길어서 메인에서 내려둔 옛 글들 — 비밀번호로 보호됩니다.</p>

    {entries.length === 0 ? (
      <p class="page-sub">아직 보관 글이 없습니다.</p>
    ) : (
      <div class="post-list">
        {entries.map((e) => (
          <a class="post-item" href={`/vault/${e.id}.html`}>
            <div class="meta">
              <span class="cat">📦 보관함</span>
              <time datetime={new Date(e.data.date).toISOString()}>{formatDate(new Date(e.data.date))}</time>
            </div>
            <h2>{e.data.title}</h2>
            {e.data.description && <p>{e.data.description}</p>}
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
