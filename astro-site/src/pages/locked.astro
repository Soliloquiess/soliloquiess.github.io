---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../lib/posts';

const entries = (await getCollection('locked'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---
<BaseLayout title="🔒 비공개 글" description="비밀번호로 보호된 글 목록" noindex={true}>
  <div class="container">
    <h1 class="page-title">🔒 비공개 글</h1>
    <p class="page-sub">비밀번호를 입력해야 볼 수 있는 글입니다.</p>

    {entries.length === 0 ? (
      <p class="page-sub">아직 비공개 글이 없습니다.</p>
    ) : (
      <div class="post-list">
        {entries.map((e) => (
          <a class="post-item" href={`/locked/${e.id}.html`}>
            <div class="meta">
              <span class="cat">🔒 비공개</span>
              <time datetime={new Date(e.data.date).toISOString()}>{formatDate(new Date(e.data.date))}</time>
            </div>
            <h2>{e.data.title}</h2>
            {e.data.description && <p>{e.data.description}</p>}
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
