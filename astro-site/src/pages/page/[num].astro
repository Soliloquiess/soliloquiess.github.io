---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostItem from '../../components/PostItem.astro';
import Pagination from '../../components/Pagination.astro';
import { getPublishedPosts } from '../../lib/posts';
import { SITE } from '../../lib/site';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  const pageSize = SITE.postsPerPage;
  const lastPage = Math.max(1, Math.ceil(posts.length / pageSize));
  const paths = [];
  // 1페이지는 index.astro가 담당 → 2페이지부터
  for (let n = 2; n <= lastPage; n++) {
    paths.push({
      params: { num: String(n) },
      props: {
        pagePosts: posts.slice((n - 1) * pageSize, n * pageSize),
        currentPage: n,
        lastPage,
      },
    });
  }
  return paths;
}) satisfies GetStaticPaths;

const { pagePosts, currentPage, lastPage } = Astro.props;
---
<BaseLayout title={`${currentPage}페이지`}>
  <div class="container">
    <div class="post-list">
      {pagePosts.map((post) => <PostItem post={post} />)}
    </div>

    <Pagination current={currentPage} last={lastPage} />
  </div>
</BaseLayout>
