---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedPosts, getPostsByYear, formatDate } from '../lib/posts';
import { postUrl } from '../lib/site';

const posts = await getPublishedPosts();
const byYear = getPostsByYear(posts);
---
<BaseLayout title="Archive" description="연도별 전체 글 목록">
  <div class="container">
    <h1 class="page-title">Archive</h1>
    <p class="page-sub">전체 {posts.length}개 글 · 연도별</p>

    {byYear.map(({ year, posts }) => (
      <section class="archive-year">
        <h2>{year} <span class="cnt">{posts.length}</span></h2>
        <ul class="archive-list">
          {posts.map((p) => (
            <li>
              <a href={postUrl(p.data.permalink)}>
                <time datetime={p.data.date.toISOString()}>{formatDate(p.data.date)}</time>
                <span class="t">{p.data.title}</span>
                <span class="c">{p.data.category}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </div>
</BaseLayout>
