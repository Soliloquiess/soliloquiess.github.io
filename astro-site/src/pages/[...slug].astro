---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Giscus from '../components/Giscus.astro';
import { getPublishedPosts, getRelatedPosts, getReadingTime, formatDate, type Post } from '../lib/posts';
import { SITE, postUrl } from '../lib/site';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  return posts.map((post, i) => ({
    params: { slug: post.data.permalink },
    props: {
      post,
      newer: i > 0 ? posts[i - 1] : null,
      older: i < posts.length - 1 ? posts[i + 1] : null,
      related: getRelatedPosts(post, posts, 4),
    },
  }));
}) satisfies GetStaticPaths;

const { post, newer, older, related } = Astro.props as {
  post: Post; newer: Post | null; older: Post | null; related: Post[];
};
const { Content, headings } = await render(post);
const { data } = post;

const readingTime = getReadingTime(post.body);
// 목차: h2·h3만, 3개 이상일 때만 노출
const toc = (headings ?? []).filter((h) => h.depth === 2 || h.depth === 3);
const showToc = toc.length >= 3;

const canonical = new URL(postUrl(data.permalink), SITE.url).href;
const iso = data.date.toISOString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  datePublished: iso,
  dateModified: iso,
  description: data.description || SITE.description,
  url: canonical,
  mainEntityOfPage: canonical,
  author: { '@type': 'Person', name: SITE.author },
  publisher: { '@type': 'Organization', name: SITE.title },
  keywords: data.tags.join(', '),
};
---
<BaseLayout title={data.title} description={data.description} type="article" image={`/og/${data.permalink}.png`}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="container">
    <article>
      <header class="article-header">
        <div class="meta">
          <span class="cat">in {data.category}</span>
          <time datetime={iso}>{formatDate(data.date)}</time>
          <span class="reading">☕ {readingTime}분 읽기</span>
        </div>
        <h1>{data.title}</h1>
        {data.tags.length > 0 && (
          <div class="tags">
            {data.tags.map((t) => <a class="tag-chip" href={`/tags/${encodeURIComponent(t)}.html`}>#{t}</a>)}
          </div>
        )}
      </header>

      {showToc && (
        <details class="toc" open>
          <summary>목차</summary>
          <nav>
            <ul>
              {toc.map((h) => (
                <li class={`d${h.depth}`}><a href={`#${h.slug}`}>{h.text}</a></li>
              ))}
            </ul>
          </nav>
        </details>
      )}

      <div class="prose" data-pagefind-body>
        <Content />
      </div>

      <nav class="post-nav">
        {older
          ? <a href={postUrl(older.data.permalink)}><span class="dir">← 이전 글</span><span class="t">{older.data.title}</span></a>
          : <span></span>}
        {newer
          ? <a class="next" href={postUrl(newer.data.permalink)}><span class="dir">다음 글 →</span><span class="t">{newer.data.title}</span></a>
          : <span></span>}
      </nav>

      {related.length > 0 && (
        <section class="related">
          <h2>관련 글</h2>
          <ul>
            {related.map((p) => (
              <li>
                <a href={postUrl(p.data.permalink)}>
                  <span class="r-cat">{p.data.category}</span>
                  <span class="r-title">{p.data.title}</span>
                  <time>{formatDate(p.data.date)}</time>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <Giscus />
    </article>
  </div>

  <!-- 코드블록 복사 버튼 + 제목 앵커 링크 -->
  <script is:inline>
    (function () {
      // 1) 코드블록 복사 버튼
      document.querySelectorAll('.prose pre').forEach(function (pre) {
        if (pre.querySelector('.copy-btn')) return;
        var btn = document.createElement('button');
        btn.className = 'copy-btn';
        btn.type = 'button';
        btn.setAttribute('aria-label', '코드 복사');
        btn.textContent = 'Copy';
        btn.addEventListener('click', function () {
          var code = pre.querySelector('code');
          var text = (code ? code.innerText : pre.innerText) || '';
          navigator.clipboard.writeText(text).then(function () {
            btn.textContent = '복사됨!';
            btn.classList.add('copied');
            setTimeout(function () { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
          }).catch(function () { btn.textContent = '실패'; });
        });
        pre.appendChild(btn);
      });

      // 2) 제목 앵커 링크 (h2·h3, id 있는 경우)
      document.querySelectorAll('.prose h2[id], .prose h3[id]').forEach(function (h) {
        if (h.querySelector('.anchor')) return;
        var a = document.createElement('a');
        a.className = 'anchor';
        a.href = '#' + h.id;
        a.setAttribute('aria-label', '이 섹션 링크');
        a.textContent = '#';
        h.appendChild(a);
      });
    })();
  </script>
</BaseLayout>
