---
import type { GetStaticPaths } from 'astro';
import { render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Giscus from '../components/Giscus.astro';
import { getPublishedPosts, getRelatedPosts, getReadingTime, getSeries, formatDate, type Post, type SeriesItem } from '../lib/posts';
import { SITE, postUrl } from '../lib/site';

export const getStaticPaths = (async () => {
  const posts = await getPublishedPosts();
  return posts.map((post, i) => ({
    params: { slug: post.data.permalink },
    props: {
      post,
      newer: i > 0 ? posts[i - 1] : null,
      older: i < posts.length - 1 ? posts[i + 1] : null,
      related: getRelatedPosts(post, posts, 4),
      series: getSeries(post, posts),
    },
  }));
}) satisfies GetStaticPaths;

const { post, newer, older, related, series } = Astro.props as {
  post: Post; newer: Post | null; older: Post | null; related: Post[]; series: SeriesItem[];
};
const { Content, headings } = await render(post);
const { data } = post;

const readingTime = getReadingTime(post.body);
// 목차: h2·h3만, 3개 이상일 때만 노출
const toc = (headings ?? []).filter((h) => h.depth === 2 || h.depth === 3);
const showToc = toc.length >= 3;

const canonical = new URL(postUrl(data.permalink), SITE.url).href;
const iso = data.date.toISOString();
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: data.title,
  datePublished: iso,
  dateModified: iso,
  description: data.description || SITE.description,
  url: canonical,
  mainEntityOfPage: canonical,
  image: [new URL(`/og/${data.permalink}.png`, SITE.url).href],
  author: { '@type': 'Person', name: SITE.author, url: SITE.url },
  publisher: {
    '@type': 'Organization',
    name: SITE.title,
    logo: { '@type': 'ImageObject', url: new URL('/assets/img/main_left.jpg', SITE.url).href },
  },
  keywords: data.tags.join(', '),
};
---
<BaseLayout title={data.title} description={data.description} type="article" image={`/og/${data.permalink}.png`}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="read-progress" aria-hidden="true"><span id="read-progress-bar"></span></div>
  <div class="container">
    <article>
      <header class="article-header">
        <div class="meta">
          <span class="cat">in {data.category}</span>
          <time datetime={iso}>{formatDate(data.date)}</time>
          <span class="reading">☕ {readingTime}분 읽기</span>
        </div>
        <h1>{data.title}</h1>
        {data.tags.length > 0 && (
          <div class="tags">
            {data.tags.map((t) => <a class="tag-chip" href={`/tags/${encodeURIComponent(t)}.html`}>#{t}</a>)}
          </div>
        )}
      </header>

      {series.length > 1 && (
        <nav class="series" aria-label="시리즈">
          <span class="series-label">📚 시리즈</span>
          <ol>
            {series.map((s) => (
              <li class={s.current ? 'current' : ''}>
                {s.current
                  ? <span>{s.part}. {s.title}</span>
                  : <a href={postUrl(s.permalink)}>{s.part}. {s.title}</a>}
              </li>
            ))}
          </ol>
        </nav>
      )}

      {showToc && (
        <details class="toc" open>
          <summary>목차</summary>
          <nav>
            <ul>
              {toc.map((h) => (
                <li class={`d${h.depth}`}><a href={`#${h.slug}`}>{h.text}</a></li>
              ))}
            </ul>
          </nav>
        </details>
      )}

      <div class="prose" data-pagefind-body>
        <Content />
      </div>

      <div class="share" data-url={canonical} data-title={data.title}>
        <span class="share-label">이 글 공유하기</span>
        <div class="share-btns">
          <button type="button" class="share-btn" data-act="native" hidden>공유</button>
          <a class="share-btn" data-act="x" href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(data.title)}&url=${encodeURIComponent(canonical)}`} rel="noopener" target="_blank">X</a>
          <a class="share-btn" data-act="fb" href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonical)}`} rel="noopener" target="_blank">Facebook</a>
          <button type="button" class="share-btn" data-act="copy">링크 복사</button>
        </div>
      </div>

      <nav class="post-nav">
        {older
          ? <a href={postUrl(older.data.permalink)}><span class="dir">← 이전 글</span><span class="t">{older.data.title}</span></a>
          : <span></span>}
        {newer
          ? <a class="next" href={postUrl(newer.data.permalink)}><span class="dir">다음 글 →</span><span class="t">{newer.data.title}</span></a>
          : <span></span>}
      </nav>

      {related.length > 0 && (
        <section class="related">
          <h2>관련 글</h2>
          <ul>
            {related.map((p) => (
              <li>
                <a href={postUrl(p.data.permalink)}>
                  <span class="r-cat">{p.data.category}</span>
                  <span class="r-title">{p.data.title}</span>
                  <time>{formatDate(p.data.date)}</time>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <Giscus />
    </article>
  </div>

  <!-- 코드블록 복사 버튼 + 제목 앵커 링크 -->
  <script is:inline>
    (function () {
      // 1) 코드블록 복사 버튼
      document.querySelectorAll('.prose pre').forEach(function (pre) {
        if (pre.querySelector('.copy-btn')) return;
        var btn = document.createElement('button');
        btn.className = 'copy-btn';
        btn.type = 'button';
        btn.setAttribute('aria-label', '코드 복사');
        btn.textContent = 'Copy';
        btn.addEventListener('click', function () {
          var code = pre.querySelector('code');
          var text = (code ? code.innerText : pre.innerText) || '';
          navigator.clipboard.writeText(text).then(function () {
            btn.textContent = '복사됨!';
            btn.classList.add('copied');
            setTimeout(function () { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 1500);
          }).catch(function () { btn.textContent = '실패'; });
        });
        pre.appendChild(btn);
      });

      // 2) 제목 앵커 링크 (h2·h3, id 있는 경우)
      document.querySelectorAll('.prose h2[id], .prose h3[id]').forEach(function (h) {
        if (h.querySelector('.anchor')) return;
        var a = document.createElement('a');
        a.className = 'anchor';
        a.href = '#' + h.id;
        a.setAttribute('aria-label', '이 섹션 링크');
        a.textContent = '#';
        h.appendChild(a);
      });

      // 2-1) 본문 이미지 lazy 보강 (raw HTML <img> 포함)
      document.querySelectorAll('.prose img:not([loading])').forEach(function (img) {
        img.setAttribute('loading', 'lazy');
        img.setAttribute('decoding', 'async');
      });

      // 2-2) 본문 이미지 클릭 확대 (라이트박스)
      (function () {
        var imgs = document.querySelectorAll('.prose img');
        if (!imgs.length) return;
        var lb = document.createElement('div');
        lb.className = 'lightbox';
        lb.innerHTML = '<button class="lb-close" type="button" aria-label="닫기">×</button><img alt=""><div class="lb-hint">클릭 또는 Esc로 닫기</div>';
        document.body.appendChild(lb);
        var lbImg = lb.querySelector('img');
        function closeLb() { lb.classList.remove('open'); document.body.style.overflow = ''; lbImg.removeAttribute('src'); }
        imgs.forEach(function (img) {
          img.addEventListener('click', function () {
            lbImg.src = img.currentSrc || img.src;
            lbImg.alt = img.alt || '';
            lb.classList.add('open');
            document.body.style.overflow = 'hidden';
          });
        });
        lb.addEventListener('click', closeLb);
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && lb.classList.contains('open')) closeLb();
        });
      })();

      // 3) 읽기 진행 바
      var bar = document.getElementById('read-progress-bar');
      var article = document.querySelector('article');
      if (bar && article) {
        var onScroll = function () {
          var top = article.offsetTop;
          var total = article.offsetHeight - window.innerHeight;
          var p = total > 0 ? (window.scrollY - top) / total : 0;
          bar.style.width = Math.max(0, Math.min(1, p)) * 100 + '%';
        };
        document.addEventListener('scroll', onScroll, { passive: true });
        window.addEventListener('resize', onScroll, { passive: true });
        onScroll();
      }

      // 4) 공유 버튼
      var share = document.querySelector('.share');
      if (share) {
        var url = share.getAttribute('data-url');
        var title = share.getAttribute('data-title');
        var nativeBtn = share.querySelector('[data-act="native"]');
        if (navigator.share && nativeBtn) {
          nativeBtn.hidden = false;
          nativeBtn.addEventListener('click', function () {
            navigator.share({ title: title, url: url }).catch(function () {});
          });
        }
        var copyBtn = share.querySelector('[data-act="copy"]');
        if (copyBtn) copyBtn.addEventListener('click', function () {
          navigator.clipboard.writeText(url).then(function () {
            var old = copyBtn.textContent;
            copyBtn.textContent = '복사됨!';
            copyBtn.classList.add('copied');
            setTimeout(function () { copyBtn.textContent = old; copyBtn.classList.remove('copied'); }, 1500);
          }).catch(function () {});
        });
      }
    })();
  </script>
</BaseLayout>
